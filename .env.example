# Required: OpenRouter API key (used by both Inspect AI evals and LLM judge)
OPENROUTER_API_KEY=sk-or-...

# Optional: Override the LLM judge model (default: openrouter/openai/gpt-5)
# ALEVAL_JUDGE_MODEL=openrouter/anthropic/claude-opus-4-20250514

# Optional: HuggingFace token (only needed if datasets are gated)
# HF_TOKEN=hf_...
